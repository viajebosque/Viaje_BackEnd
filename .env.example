# Puerto: Railway lo inyecta automáticamente. Local usa 3000.
PORT=3000
NODE_ENV=development

# Supabase (proyecto Dev o Prod según ambiente)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Orígenes permitidos para CORS (frontend Vercel), separados por coma
CORS_ORIGINS=http://localhost:5173
